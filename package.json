{
  "name": "eslint-plugin-func-params-args",
  "version": "6.0.0",
  "description": "Limit the number of function parameters and arguments with ease and flexibility",
  "author": "Abdulrahman (Abdu) Assabri <abdusabri@abdusabri.com>",
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin",
    "function",
    "func",
    "args",
    "params",
    "parameters",
    "arguments"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/abdusabri/eslint-plugin-func-params-args.git"
  },
  "homepage": "https://github.com/abdusabri/eslint-plugin-func-params-args",
  "bugs": {
    "url": "https://github.com/abdusabri/eslint-plugin-func-params-args/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20.9.0"
  },
  "main": "dist/index.js",
  "scripts": {
    "lint": "eslint lib/rules/ tests/lib/rules/",
    "prettier:fix": "prettier --write **/*.{js,mjs,json,md}",
    "prettier:check": "prettier --check **/*.{js,mjs,json,md}",
    "test:unit": "mocha tests --recursive",
    "test": "nyc mocha tests --recursive",
    "check-coverage": "nyc check-coverage --statements 100 --branches 100 --functions 100 --lines 100",
    "cover": "nyc report --reporter=lcov",
    "coveralls": "cat ./coverage/lcov.info | coveralls",
    "build": "rimraf dist && minify lib -d dist"
  },
  "dependencies": {
    "@eslint-community/eslint-utils": "^4.4.0",
    "requireindex": "~1.2.0"
  },
  "peerDependencies": {
    "eslint": "^8.57.0 || ^9.0.0 || ^10.0.0"
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^8.0.0",
    "babel-minify": "^0.5.1",
    "coveralls": "^3.1.0",
    "eslint": "9.39.4",
    "eslint-plugin-eslint-plugin": "^7.3.1",
    "husky": "^9.0.0",
    "lint-staged": "^16.0.0",
    "mocha": "^11.0.0",
    "nyc": "^18.0.0",
    "prettier": "^3.1.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.0.2"
  },
  "files": [
    "*.md",
    "LICENSE",
    "docs",
    "dist"
  ],
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,mjs,json,md}": "prettier --write"
  }
}
